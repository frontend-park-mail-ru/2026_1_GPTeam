<div class="transactions-page">
    <section class="transactions-hero">
        <div class="transactions-hero__copy">
            <h1 class="transactions-page__title">Транзакции</h1>
            <p class="transactions-page__subtitle">
                Единый журнал доходов и расходов с категоризацией, фильтрами и быстрыми действиями.
            </p>
        </div>

        <button class="transactions-hero__button" type="button">
            Новая транзакция
        </button>
    </section>

    <div class="transactions-filters" aria-label="Фильтры транзакций">
        {{#each filters}}
            <button class="{{class_name}}" type="button">
                {{label}}
            </button>
        {{/each}}
    </div>

    <section class="transactions-stats">
        {{#each stats}}
            <article class="{{class_name}}">
                <p class="transactions-stat__label">{{label}}</p>
                <p class="transactions-stat__value">{{value}}</p>
            </article>
        {{/each}}
    </section>

    <section class="transactions-feed">
        <div class="transactions-feed__header">
            <h2 class="transactions-feed__title">Последние транзакции</h2>
            <p class="transactions-feed__description">
                Категория отображается как тег с иконкой и может быть изменена в форме редактирования.
            </p>
        </div>

        <div class="transactions-feed__divider"></div>
        <div class="transactions-feed__list" id="transactions_list"></div>
    </section>
</div>
