<div class="appeal-card">
    <div class="appeal-card__header">
        <span class="appeal-card__category">{{category}}</span>
        <span class="appeal-card__status appeal-card__status--{{statusType}}">{{status}}</span>
    </div>
    <p class="appeal-card__message">{{message}}</p>
    <div class="appeal-card__footer">
        <span class="appeal-card__id">#{{id}}</span>
        <span class="appeal-card__date">{{date}}</span>
    </div>
</div>
