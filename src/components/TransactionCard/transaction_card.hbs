<article class="transaction-card transaction-card--{{type}}">
    <div class="transaction-card__left">
        <div class="transaction-card__icon-shell">
            <div class="transaction-card__icon">{{category_icon}}</div>
        </div>

        <div class="transaction-card__content">
            <h3 class="transaction-card__title">{{title}}</h3>

            <div class="transaction-card__meta">
                <span class="transaction-card__meta-item">{{date}}</span>
                {{#if note}}
                    <span class="transaction-card__meta-item">{{note}}</span>
                {{/if}}
            </div>
        </div>
    </div>

    <div class="transaction-card__right">
        <p class="transaction-card__amount transaction-card__amount--{{type}}">
            {{amount_sign}}{{currency}} {{amount}}
        </p>

        <div class="transaction-card__actions">
            <button class="transaction-card__action-btn" type="button" data-action="edit">
                Изменить
            </button>
            <button class="transaction-card__action-btn transaction-card__action-btn--danger" type="button" data-action="delete">
                Удалить
            </button>
        </div>
    </div>
</article>
