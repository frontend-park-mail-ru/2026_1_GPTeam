<div class="profile-info-cards">
    <div class="profile-info-card">
        <div class="profile-info-card__label">Логин</div>
        <div class="profile-info-card__value">{{username}}</div>
    </div>
    <div class="profile-info-card">
        <div class="profile-info-card__label">Email</div>
        <div class="profile-info-card__value">{{email}}</div>
    </div>
    <div class="profile-info-card profile-info-card--wide">
        <div class="profile-info-card__label">Дата регистрации</div>
        <div class="profile-info-card__value">{{created_at}}</div>
    </div>
</div>