<form>
    <h3>Регистрация</h3>
    <input id="username_input" type="text" name="username" placeholder="Имя" autocomplete="off">
    <input id="password_input" type="password" name="password" placeholder="Пароль" autocomplete="off">
    {{#equal mode "signup"}}
        <input id="confirm_password_input" type="password" name="confirm_password" placeholder="Пароль снова" autocomplete="off">
        <input id="email_input" type="email" name="email" placeholder="Email" autocomplete="off">
    {{/equal}}
    <p id="error_message"></p>
    {{#equal mode "login"}}
        <input type="submit" value="Войти">
        <p>Ещё нет аккаунта? <a href="/signup">Зарегистрироваться</a></p>
    {{else}}
        <input type="submit" value="Зарегистрироваться">
        <p>Уже есть аккаунт? <a href="/login">Войти</a></p>
    {{/equal}}
</form>